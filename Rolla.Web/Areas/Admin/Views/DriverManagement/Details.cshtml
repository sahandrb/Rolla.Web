@using Rolla.Application.DTOs.Admin
@using Rolla.Domain.Enums
@model DriverDetailsDto

@{
    ViewData["Title"] = "پرونده راننده | " + Model.Email;
}

<style>
    /* ==========================================
           1. Base Variables & Overrides
           ========================================== */
    body {
        background-color: #f8fafc;
        font-family: system-ui, -apple-system, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    }

    /* ==========================================
           2. Typography & Badges
           ========================================== */
    .text-slate-900 {
        color: #0f172a;
    }

    .text-slate-500 {
        color: #64748b;
    }

    .status-glowing {
        position: relative;
        padding: 8px 18px;
        border-radius: 50px;
        font-weight: 800;
        font-size: 0.9rem;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        z-index: 1;
        overflow: hidden;
    }

        .status-glowing.pending {
            background: #fffbeb;
            color: #d97706;
            border: 1px solid #fde68a;
        }

        .status-glowing.approved {
            background: #f0fdf4;
            color: #16a34a;
            border: 1px solid #bbf7d0;
        }

        .status-glowing.rejected {
            background: #fef2f2;
            color: #dc2626;
            border: 1px solid #fecaca;
        }

    /* ==========================================
           3. Cards & Containers
           ========================================== */
    .admin-glass-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border-radius: 28px;
        border: 1px solid #f1f5f9;
        box-shadow: 0 20px 40px -15px rgba(0,0,0,0.05);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .doc-card {
        border-radius: 20px;
        overflow: hidden;
        background: white;
        border: 1px solid #e2e8f0;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

        .doc-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 25px 50px -12px rgba(0,0,0,0.12);
            border-color: #cbd5e1;
        }

    /* ==========================================
           4. Graphic Iran License Plate
           ========================================== */
    .iran-plate {
        display: inline-flex;
        align-items: center;
        background: #ffffff;
        border: 2px solid #000;
        border-radius: 6px;
        height: 45px;
        font-family: "Arial", sans-serif;
        font-weight: 900;
        font-size: 1.3rem;
        color: #000;
        overflow: hidden;
        box-shadow: inset 0 2px 5px rgba(0,0,0,0.1);
        direction: ltr; /* پلاک از چپ به راست خوانده میشود */
    }

    .iran-plate-blue {
        background: #1d4ed8;
        color: white;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 0 6px;
        font-size: 0.6rem;
    }

        .iran-plate-blue img {
            width: 14px;
            margin-bottom: 2px;
        }

    .iran-plate-numbers {
        padding: 0 12px;
        letter-spacing: 2px;
    }

    .iran-plate-letter {
        font-size: 1.1rem;
        margin: 0 4px;
    }

    .iran-plate-divider {
        height: 100%;
        width: 2px;
        background: #000;
    }

    .iran-plate-city {
        padding: 0 10px;
        font-size: 1.1rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        line-height: 1;
    }

        .iran-plate-city span:first-child {
            font-size: 0.6rem;
            font-weight: normal;
            margin-bottom: 2px;
        }

    /* ==========================================
           5. Image Viewer & Overlay
           ========================================== */
    .img-wrapper {
        position: relative;
        height: 280px;
        width: 100%;
        overflow: hidden;
        background: #f8fafc;
        cursor: pointer;
    }

        .img-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }

    .img-overlay {
        position: absolute;
        inset: 0;
        background: rgba(15, 23, 42, 0.4);
        backdrop-filter: blur(3px);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: all 0.3s ease;
    }

    .img-wrapper:hover .img-overlay {
        opacity: 1;
    }

    .img-wrapper:hover img {
        transform: scale(1.08);
    }

    .view-btn {
        background: white;
        color: #0f172a;
        padding: 12px 24px;
        border-radius: 50px;
        font-weight: bold;
        transform: translateY(20px);
        transition: all 0.3s ease;
    }

    .img-wrapper:hover .view-btn {
        transform: translateY(0);
    }

    /* ==========================================
           6. Custom Lightbox (Image Modal)
           ========================================== */
    #lightbox {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: rgba(0, 0, 0, 0.9);
        backdrop-filter: blur(10px);
        z-index: 9999;
        display: none;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.3s ease;
    }

        #lightbox.show {
            display: flex;
            opacity: 1;
        }

        #lightbox img {
            max-width: 90%;
            max-height: 90vh;
            border-radius: 16px;
            box-shadow: 0 25px 50px rgba(0,0,0,0.5);
            transform: scale(0.95);
            transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        #lightbox.show img {
            transform: scale(1);
        }

    .lightbox-close {
        position: absolute;
        top: 30px;
        right: 40px;
        color: white;
        font-size: 2.5rem;
        cursor: pointer;
        transition: color 0.2s;
    }

        .lightbox-close:hover {
            color: #ef4444;
        }

    /* ==========================================
           7. Buttons & Action Modals
           ========================================== */
    .btn-action-main {
        border-radius: 16px;
        padding: 14px 20px;
        font-weight: 800;
        font-size: 1.05rem;
        border: none;
        transition: all 0.2s;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 10px;
    }

        .btn-action-main:active {
            transform: scale(0.96);
        }

    .btn-approve-modern {
        background: #22c55e;
        color: white;
        box-shadow: 0 10px 25px rgba(34, 197, 94, 0.3);
    }

        .btn-approve-modern:hover {
            background: #16a34a;
            box-shadow: 0 15px 35px rgba(34, 197, 94, 0.4);
        }

    .btn-reject-modern {
        background: #fff1f2;
        color: #e11d48;
        border: 2px solid #ffe4e6;
    }

        .btn-reject-modern:hover {
            background: #ffe4e6;
            border-color: #fecdd3;
        }

</style>

<div class="container mt-5 mb-5 fade-in-section">

    <!-- Top Header -->
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="fw-bold text-slate-900 mb-1">
                <i class="bi bi-folder-check text-primary me-2"></i> پرونده راننده
            </h2>
            <p class="text-slate-500 mb-0 ms-1">در حال بررسی مدارک آپلود شده توسط کاربر</p>
        </div>
        <a asp-action="Index" class="btn btn-light rounded-pill fw-bold px-4 shadow-sm border">
            <i class="bi bi-arrow-right me-1"></i> بازگشت
        </a>
    </div>

    <div class="row g-5">
        <!-- Sidebar: Driver Profile -->
        <div class="col-lg-4">
            <div class="admin-glass-card p-4 text-center h-100 position-relative overflow-hidden">

                <!-- Decorative Background Blur -->
                <div class="position-absolute top-0 start-0 w-100 bg-primary opacity-10" style="height: 120px; filter: blur(20px);"></div>

                <!-- Avatar -->
                <div class="position-relative z-1 mb-4 mt-2">
                    <div class="bg-white rounded-circle d-flex align-items-center justify-content-center mx-auto shadow-sm border" style="width: 100px; height: 100px;">
                        <i class="bi bi-person-bounding-box text-primary" style="font-size: 2.5rem;"></i>
                    </div>
                </div>

                <!-- Info -->
                <h4 class="fw-bold text-slate-900 mb-1">@(string.IsNullOrEmpty(Model.FullName) ? "کاربر ناشناس" : Model.FullName)</h4>
                <p class="text-slate-500 mb-4" dir="ltr">@Model.Email</p>

                <!-- Status Badge -->
                <div class="mb-5">
                    @if (Model.Status == DriverStatus.Pending)
                    {
                        <span class="status-glowing pending">
                            <span class="spinner-grow spinner-grow-sm text-warning" role="status"></span>
                            در انتظار تایید شما
                        </span>
                    }
                    else if (Model.Status == DriverStatus.Approved)
                    {
                        <span class="status-glowing approved">
                            <i class="bi bi-patch-check-fill fs-5"></i> تایید شده و فعال
                        </span>
                    }
                    else
                    {
                        <span class="status-glowing rejected">
                            <i class="bi bi-x-octagon-fill fs-5"></i> رد شده
                        </span>
                    }
                </div>

                <!-- Vehicle Details -->
                <div class="bg-slate-50 rounded-4 p-4 text-start mb-5" style="background: #f1f5f9; border: 1px solid #e2e8f0;">
                    <div class="mb-4">
                        <small class="text-slate-500 d-block fw-bold mb-1"><i class="bi bi-car-front me-1"></i> مدل خودرو:</small>
                        <span class="fw-bold fs-5 text-slate-900">@Model.CarModel</span>
                    </div>

                    <div>
                        <small class="text-slate-500 d-block fw-bold mb-2"><i class="bi bi-123 me-1"></i> شماره پلاک ثبت شده:</small>

                        <!-- Beautiful Iranian License Plate Render -->
                        @{
                            // یک لاجیک ساده برای تکه کردن رشته پلاک برای نمایش گرافیکی (اختیاری)
                            // فرض میکنیم کاربر اینطوری وارد کرده: 12ب345-67
                            var plateStr = Model.PlateNumber.Replace("-", "").Replace(" ", "");
                        }
                        <div class="iran-plate w-100 justify-content-between">
                            <div class="iran-plate-blue">
                                <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/c/ca/Flag_of_Iran.svg/120px-Flag_of_Iran.svg.png" alt="IR">
                                I.R.<br>IRAN
                            </div>
                            <div class="iran-plate-numbers d-flex align-items-center flex-grow-1 justify-content-center">
                                @Model.PlateNumber
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Action Buttons (Only if Pending) -->
                @if (Model.Status == DriverStatus.Pending)
                {
                    <div class="d-grid gap-3">
                        <button type="button" class="btn-action-main btn-approve-modern" data-bs-toggle="modal" data-bs-target="#approveModal">
                            <i class="bi bi-check2-all fs-5"></i> تایید نهایی مدارک
                        </button>

                        <button type="button" class="btn-action-main btn-reject-modern" data-bs-toggle="modal" data-bs-target="#rejectModal">
                            <i class="bi bi-trash3 fs-5"></i> رد و نقص مدرک
                        </button>
                    </div>
                }
            </div>
        </div>

        <!-- Main Content: Documents Grid -->
        <div class="col-lg-8">
            <div class="admin-glass-card p-5 h-100">
                <div class="d-flex align-items-center border-bottom pb-4 mb-5">
                    <div class="bg-primary bg-opacity-10 text-primary rounded px-3 py-2 me-3">
                        <i class="bi bi-images fs-4"></i>
                    </div>
                    <h4 class="fw-bold text-slate-900 mb-0">مدارک احراز هویت</h4>
                </div>

                <div class="row g-4">
                    @foreach (var doc in Model.Documents)
                    {
                        var icon = "bi-file-earmark-image";
                        var title = "سایر مدارک";
                        var color = "text-secondary";

                        if (doc.Type == DocumentType.NationalCard) { icon = "bi-person-vcard"; title = "کارت ملی (روی کارت)"; color = "text-primary"; }
                        if (doc.Type == DocumentType.DriverLicense) { icon = "bi-card-heading"; title = "گواهینامه رانندگی"; color = "text-warning"; }
                        if (doc.Type == DocumentType.CarPhoto) { icon = "bi-car-front-fill"; title = "تصویر واضح خودرو"; color = "text-success"; }

                        // ساخت URL دریافت عکس از کنترلر
                        var imgUrl = Url.Action("GetDocumentImage", "DriverManagement", new { id = doc.Id });

                        <div class="col-md-6">
                            <div class="doc-card">
                                <div class="p-3 d-flex align-items-center bg-white border-bottom">
                                    <i class="bi @icon @color fs-4 me-2"></i>
                                    <span class="fw-bold text-slate-900">@title</span>
                                </div>

                                <div class="img-wrapper" onclick="openLightbox('@imgUrl', '@title')">
                                    <img src="@imgUrl" alt="@title" loading="lazy" />
                                    <div class="img-overlay">
                                        <div class="view-btn shadow">
                                            <i class="bi bi-zoom-in me-1"></i> مشاهده بزرگنمایی
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }

                    @if (!Model.Documents.Any())
                    {
                        <div class="col-12 py-5 text-center">
                            <div class="d-inline-flex flex-column align-items-center opacity-50">
                                <i class="bi bi-folder-x display-1 mb-3 text-slate-500"></i>
                                <h4 class="text-slate-500 fw-bold">هیچ مدرکی آپلود نشده است</h4>
                                <p>کاربر فرآیند ثبت‌نام را کامل نکرده است.</p>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ==========================================
     LightBox (Full Screen Image Viewer)
     ========================================== -->
<div id="lightbox" onclick="closeLightbox(event)">
    <i class="bi bi-x-lg lightbox-close"></i>
    <img id="lightbox-img" src="" alt="Zoomed Document" onclick="event.stopPropagation()" />
</div>

<!-- ==========================================
     Modals (Approve / Reject Confirmation)
     ========================================== -->
<!-- Approve Modal -->
<div class="modal fade" id="approveModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow-lg">
            <div class="modal-body p-5 text-center">
                <div class="bg-success bg-opacity-10 text-success rounded-circle d-inline-flex p-4 mb-4">
                    <i class="bi bi-shield-check display-4"></i>
                </div>
                <h3 class="fw-bold mb-3">تایید نهایی راننده؟</h3>
                <p class="text-slate-500 mb-4 lh-lg">با کلیک روی دکمه زیر، مدارک این کاربر تایید شده و می‌تواند فوراً به عنوان راننده در سیستم مسافر سوار کند.</p>

                <form asp-action="Approve" method="post" class="d-flex gap-3 mt-4">
                    <input type="hidden" name="userId" value="@Model.Id" />
                    <button type="button" class="btn btn-light rounded-pill px-4 fw-bold flex-grow-1" data-bs-dismiss="modal">انصراف</button>
                    <button type="submit" class="btn btn-success rounded-pill px-4 fw-bold flex-grow-1 shadow-sm">بله، تایید میکنم</button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Reject Modal -->
<div class="modal fade" id="rejectModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow-lg">
            <div class="modal-body p-5 text-center">
                <div class="bg-danger bg-opacity-10 text-danger rounded-circle d-inline-flex p-4 mb-4">
                    <i class="bi bi-exclamation-triangle display-4"></i>
                </div>
                <h3 class="fw-bold mb-3 text-danger">رد کردن مدارک؟</h3>
                <p class="text-slate-500 mb-4 lh-lg">در صورت رد کردن، مدارک منقضی شده و حساب کاربر به عنوان راننده فعال نخواهد شد.</p>

                <form asp-action="Reject" method="post" class="d-flex gap-3 mt-4">
                    <input type="hidden" name="userId" value="@Model.Id" />
                    <button type="button" class="btn btn-light rounded-pill px-4 fw-bold flex-grow-1" data-bs-dismiss="modal">بازگشت</button>
                    <button type="submit" class="btn btn-danger rounded-pill px-4 fw-bold flex-grow-1 shadow-sm">بله، رد شود</button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- ==========================================
     Scripts for UI Logic
     ========================================== -->
@section Scripts {
    <script>
        // Lightbox Logic
        const lightbox = document.getElementById('lightbox');
        const lightboxImg = document.getElementById('lightbox-img');

        function openLightbox(imgSrc, title) {
            lightboxImg.src = imgSrc;
            lightboxImg.alt = title;
            lightbox.classList.add('show');
            document.body.style.overflow = 'hidden'; // قفل کردن اسکرول صفحه
        }

        function closeLightbox(event) {
            // جلوگیری از بسته شدن اگر روی خود عکس کلیک شد
            if(event && event.target === lightboxImg) return;

            lightbox.classList.remove('show');
            document.body.style.overflow = 'auto'; // باز کردن اسکرول

            setTimeout(() => { lightboxImg.src = ''; }, 300); // پاک کردن سورس بعد از انیمیشن
        }

        // بستن با دکمه Esc کیبورد
        document.addEventListener('keydown', function(event) {
            if (event.key === "Escape" && lightbox.classList.contains('show')) {
                closeLightbox();
            }
        });
    </script>
}
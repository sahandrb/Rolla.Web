@using System.Security.Claims

@{
    ViewData["Title"] = "درخواست سفر";
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
}

<!-- استایل‌های اختصاصی برای تبدیل صفحه به اپلیکیشن (App-like UI) -->
<style>
    /* مخفی کردن هدر سایت و اسکرول بادی فقط در این صفحه */
    header {
        display: none !important;
    }

    body {
        padding: 0 !important;
        margin: 0 !important;
        overflow: hidden;
        background: #eee;
    }

    /* کانتینر اصلی تمام‌صفحه */
    .app-wrapper {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        z-index: 1000;
    }

    /* نقشه در لایه زیرین */
    #map {
        width: 100%;
        height: 100vh;
        z-index: 1;
    }

    /* دکمه‌های شناور بالای صفحه (مانند اسنپ) */
    .fab-btn {
        position: absolute;
        top: 20px;
        background: white;
        border: none;
        border-radius: 50%;
        width: 45px;
        height: 45px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.15);
        z-index: 1001;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        color: #333;
        transition: transform 0.2s;
    }

        .fab-btn:active {
            transform: scale(0.9);
        }

    .fab-top-right {
        right: 20px;
    }

    .fab-top-left {
        left: 20px;
    }

    /* نشانگر نوع سرویس (برای خودم) */
    .fab-top-center {
        position: absolute;
        top: 20px;
        left: 50%;
        transform: translateX(-50%);
        background: white;
        padding: 10px 20px;
        border-radius: 30px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.15);
        z-index: 1001;
        font-weight: bold;
        font-size: 0.9rem;
        color: #333;
    }

    /* پنل سفید پایین صفحه (Bottom Sheet) */
    .bottom-sheet {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        background: white;
        border-radius: 25px 25px 0 0;
        padding: 25px 20px 30px 20px;
        z-index: 1001;
        box-shadow: 0 -5px 25px rgba(0,0,0,0.1);
        display: flex;
        flex-direction: column;
        align-items: center;
        transition: all 0.3s ease;
    }

    /* وضعیت فعلی (متن راهنما و قیمت) */
    .status-text {
        font-size: 1.1rem;
        color: #555;
        font-weight: bold;
        margin-bottom: 5px;
        text-align: center;
    }

    .price-text {
        font-size: 1.8rem;
        color: #22c55e;
        font-weight: 900;
        display: none;
        margin-bottom: 15px;
    }

    /* دکمه اصلی پایین صفحه */
    .btn-main-action {
        background-color: #22c55e;
        color: white;
        border: none;
        border-radius: 15px;
        padding: 16px;
        font-size: 1.2rem;
        font-weight: bold;
        width: 100%;
        max-width: 500px;
        transition: 0.2s;
        box-shadow: 0 4px 15px rgba(34, 197, 94, 0.3);
    }

        .btn-main-action:active {
            transform: scale(0.98);
            background-color: #16a34a;
        }

        .btn-main-action:disabled {
            background-color: #cbd5e1;
            box-shadow: none;
            cursor: not-allowed;
            color: #64748b;
        }

</style>

<div class="app-wrapper">
    <!-- لایه ۱: نقشه -->
    <div id="map"></div>

    <!-- لایه ۲: دکمه‌های کنترلی بالای صفحه -->
    <!-- دکمه بازگشت به داشبورد/خانه -->
    <button class="fab-btn fab-top-right" onclick="location.href='/'"><i class="bi bi-arrow-right"></i></button>
    <!-- دکمه پروفایل/کیف پول -->
    <button class="fab-btn fab-top-left" onclick="location.href='/Wallet/Index'"><i class="bi bi-wallet2"></i></button>

    <div class="fab-top-center">برای خودم <i class="bi bi-chevron-down ms-1"></i></div>

    <!-- لایه ۳: پنل پایین (Bottom Sheet) -->
    <div class="bottom-sheet" id="bottom-sheet">

        <!-- متن راهنمای کاربر (کجا می‌روید و...) -->
        <div id="status-guide" class="status-text">📍 مبدأ را روی نقشه انتخاب کنید</div>

        <!-- قیمت که فقط در مرحله ۳ نمایش داده می‌شود -->
        <div id="price-display" class="price-text">0 تومان</div>

        <!-- دکمه اصلی (متصل به لاجیک قدیمی شما) -->
        <button id="btn-request" class="btn-main-action" disabled onclick="submitRequest()">
            درخواست رولا
        </button>

    </div>
</div>

<!-- ============================================== -->
<!-- کدهای مربوط به چت (همان قبلی‌ها بدون تغییر) -->
<!-- ============================================== -->
<div id="chatBox" class="card shadow" style="display:none; position:fixed; bottom:130px; right:20px; width:300px; z-index:2000; border-radius: 15px;">
    <div class="card-header bg-primary text-white d-flex justify-content-between" style="border-radius: 15px 15px 0 0;">
        <span>💬 چت با راننده</span>
        <button class="btn-close btn-close-white" onclick="toggleChat()"></button>
    </div>
    <div id="chatMessages" class="card-body" style="height:200px; overflow-y:auto; font-size:14px; background: #f8f9fa;"></div>
    <div class="card-footer p-2 bg-white" style="border-radius: 0 0 15px 15px;">
        <div class="input-group">
            <input type="text" id="chatInput" class="form-control" placeholder="پیام...">
            <button class="btn btn-primary" onclick="sendChatMessage()"><i class="bi bi-send"></i></button>
        </div>
    </div>
</div>
<button id="btn-open-chat" class="btn btn-info rounded-circle shadow-lg" style="display:none; position:fixed; bottom:130px; right:20px; width:60px; height:60px; z-index:1999; font-size: 1.5rem;" onclick="toggleChat()">💬</button>


@section Scripts {
    <script>
        // متغیر شناسه کاربر برای لاجیک سیگنال آر
        var currentUserId = '@currentUserId';
    </script>

    <!-- فایل‌های لاجیک اصلی شما (بدون هیچ تغییری) -->
    <script src="~/js/core/map-base.js"></script>
    <script src="~/js/logic/rider-logic.js"></script>

    <!-- کدهای رابط کاربری (UI) برای هماهنگی با فایل rider-logic.js -->
    <script>
        // برای اینکه وقتی لاجیک شما (step 1, 2) عوض می‌شود، ظاهر هم تغییر کند
        // ما از یک Observer روی دکمه استفاده می‌کنیم یا کلیک نقشه را مانیتور می‌کنیم.

        // چون در rider-logic.js شما روی نقشه کلیک می‌کنید و step تغییر می‌کند:
        document.addEventListener("DOMContentLoaded", function () {

            // گوش دادن به کلیک روی نقشه (بعد از لود شدن نقشه)
            setTimeout(() => {
                if(map) {
                    map.on('click', function () {
                        const guide = document.getElementById('status-guide');
                        const price = document.getElementById('price-display');
                        const btn = document.getElementById('btn-request');

                        if (step === 2) {
                            // مبدا انتخاب شده، منتظر مقصد
                            guide.innerHTML = "🏁 مقصد را روی نقشه انتخاب کنید";
                            guide.style.color = "#ef4444"; // رنگ قرمز
                            btn.innerText = "انتخاب مقصد";
                        }
                        else if (step === 3 || btn.getAttribute('data-price')) {
                            // مقصد انتخاب شده و قیمت محاسبه شده
                            guide.innerHTML = "هزینه سفر شما:";
                            guide.style.fontSize = "0.9rem";
                            guide.style.color = "#888";

                            // نمایش قیمت و تغییر رنگ دکمه (کد محاسبه قیمت در rider-logic.js مقدار دهی می‌کند)
                            price.style.display = "block";
                            btn.style.backgroundColor = "#22c55e"; // سبز اسنپی
                        }
                    });
                }
            }, 1000);

            // یک Observer روی تگ قیمت می‌گذاریم تا وقتی rider-logic.js قیمت را نوشت، UI را آپدیت کنیم
            const priceTarget = document.getElementById('price-display');
            const observer = new MutationObserver(function(mutations) {
                if(priceTarget.innerText !== "0 تومان" && priceTarget.innerText !== "در حال محاسبه...") {
                    priceTarget.style.display = "block";
                    document.getElementById('status-guide').innerText = "هزینه سفر شما:";
                    document.getElementById('status-guide').style.fontSize = "0.9rem";
                }
            });
            observer.observe(priceTarget, { childList: true, characterData: true, subtree: true });
        });


    </script>
}
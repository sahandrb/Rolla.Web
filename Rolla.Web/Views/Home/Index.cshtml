@using Microsoft.AspNetCore.Identity
@using Rolla.Domain.Entities
@using Rolla.Domain.Common.Constants
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@{
    ViewData["Title"] = "رولا - سیستم هوشمند درخواست خودرو";
    // دریافت اطلاعات کاربر در صورت لاگین بودن
    ApplicationUser? currentUser = null;
    if (SignInManager.IsSignedIn(User))
    {
        currentUser = await UserManager.GetUserAsync(User);
    }
}

<style>
    /* مخفی کردن هدر و فوتر سایت فقط در صفحه ورود */
    header, footer {
        display: none !important;
    }

    body {
        padding: 0 !important;
        margin: 0 !important;
        overflow: hidden;
        background-color: #ffffff;
    }

    /* ساختار دونیمه (Split Screen) */
    .split-layout {
        display: flex;
        width: 100vw;
        height: 100vh;
        position: fixed;
        top: 0;
        left: 0;
        z-index: 1000;
        direction: rtl;
    }

    /* ------------------------------------- */
    /* نیمه راست: بخش نقشه */
    /* ------------------------------------- */
    .map-section {
        width: 50%;
        height: 100%;
        position: relative;
    }

    #map {
        width: 100%;
        height: 100%;
        z-index: 1;
    }

    .map-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(to left, rgba(0,0,0,0.4) 0%, rgba(0,0,0,0) 40%);
        z-index: 2;
        pointer-events: none;
    }

    .brand-on-map {
        position: absolute;
        top: 40px;
        right: 40px;
        z-index: 3;
        color: white;
        font-size: 3rem;
        font-weight: 900;
        text-shadow: 0 4px 15px rgba(0,0,0,0.3);
        letter-spacing: 2px;
    }

    .brand-dot {
        color: #22c55e;
    }

    /* ------------------------------------- */
    /* نیمه چپ: بخش محتوا و ورود */
    /* ------------------------------------- */
    .content-section {
        width: 50%;
        height: 100%;
        background-color: #ffffff;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        z-index: 10;
        box-shadow: -10px 0 30px rgba(0,0,0,0.05);
        overflow-y: auto; /* برای گوشی‌های کوچک که محتوا زیاد است */
    }

    .login-panel {
        width: 100%;
        max-width: 450px;
        padding: 40px;
    }

    /* استایل پایه دکمه‌های مدرن */
    .btn-modern {
        border-radius: 16px;
        padding: 16px 20px;
        font-weight: 800;
        font-size: 1.1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
        border: none;
        width: 100%;
        margin-bottom: 15px;
        cursor: pointer;
    }

        .btn-modern:hover {
            transform: translateY(-3px);
        }

        .btn-modern:active {
            transform: scale(0.97);
        }

    /* رنگ‌بندی اختصاصی دکمه‌ها */
    .btn-rider {
        background: #4f46e5;
        color: white;
        box-shadow: 0 8px 20px rgba(79, 70, 229, 0.25);
    }

        .btn-rider:hover {
            background: #4338ca;
            color: white;
            box-shadow: 0 12px 25px rgba(79, 70, 229, 0.35);
        }

    .btn-driver {
        background: #22c55e;
        color: white;
        box-shadow: 0 8px 20px rgba(34, 197, 94, 0.25);
    }

        .btn-driver:hover {
            background: #16a34a;
            color: white;
            box-shadow: 0 12px 25px rgba(34, 197, 94, 0.35);
        }

    .btn-admin {
        background: #e11d48;
        color: white;
        box-shadow: 0 8px 20px rgba(225, 29, 72, 0.25);
    }

        .btn-admin:hover {
            background: #be123c;
            color: white;
            box-shadow: 0 12px 25px rgba(225, 29, 72, 0.35);
        }

    /* دکمه ورود (جدید) */
    .btn-auth-login {
        background: #0f172a;
        color: white;
        box-shadow: 0 8px 20px rgba(15, 23, 42, 0.25);
    }

        .btn-auth-login:hover {
            background: #1e293b;
            color: white;
            box-shadow: 0 12px 25px rgba(15, 23, 42, 0.35);
        }

    /* دکمه خروج (جدید) */
    .btn-auth-logout {
        background: #fff1f2;
        color: #e11d48;
        border: 2px solid #ffe4e6;
    }

        .btn-auth-logout:hover {
            background: #ffe4e6;
            border-color: #fecdd3;
            color: #be123c;
        }

    .btn-register {
        background: white;
        color: #22c55e;
        border: 2px solid #22c55e;
    }

        .btn-register:hover {
            background: #f0fdf4;
            color: #16a34a;
        }

    /* استاتوس بار زنده */
    .live-status {
        background: #f8f9fa;
        border-radius: 12px;
        padding: 12px 15px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.85rem;
        font-weight: bold;
        margin-bottom: 30px;
        border: 1px solid #eee;
    }

    .status-dot {
        width: 10px;
        height: 10px;
        background: #22c55e;
        border-radius: 50%;
        display: inline-block;
        animation: pulse 1.5s infinite;
    }

    @@keyframes pulse {
        0%

    {
        box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.4);
    }

    70% {
        box-shadow: 0 0 0 8px rgba(34, 197, 94, 0);
    }

    100% {
        box-shadow: 0 0 0 0 rgba(34, 197, 94, 0);
    }

    }

    /* باکس کاربری */
    .user-welcome-box {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        padding: 15px 20px;
        display: flex;
        align-items: center;
        margin-bottom: 25px;
    }

    /* ------------------------------------- */
    /* رسپانسیو (موبایل و تبلت) */
    /* ------------------------------------- */
    @@media (max-width: 991px) {
        .split-layout

    {
        flex-direction: column;
    }

    .map-section {
        width: 100%;
        height: 40vh;
    }

    .brand-on-map {
        top: 20px;
        right: 20px;
        font-size: 2rem;
    }

    .content-section {
        width: 100%;
        height: 60vh;
        border-radius: 30px 30px 0 0;
        margin-top: -30px;
        align-items: flex-start;
        padding-top: 10px;
    }

    .login-panel {
        padding: 25px;
        max-width: 100%;
    }

    }
</style>

<div class="split-layout">

    <!-- نیمه راست: نقشه -->
    <div class="map-section">
        <div class="brand-on-map">ROLLA<span class="brand-dot">.</span></div>
        <div class="map-overlay"></div>
        <div id="map"></div>
    </div>

    <!-- نیمه چپ: پنل اصلی -->
    <div class="content-section">
        <div class="login-panel">

            <div class="mb-4">
                <h1 class="fw-bold text-dark mb-2">سلام! 👋</h1>
                <p class="text-muted" style="font-size: 1rem;">برای شروع حرکت با رولا، یکی از گزینه‌های زیر را انتخاب کنید.</p>
            </div>

            <!-- کارت خوش‌آمدگویی (فقط در صورت لاگین بودن) -->
            @if (currentUser != null)
            {
                <div class="user-welcome-box shadow-sm">
                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 45px; height: 45px;">
                        <i class="bi bi-person-fill fs-4"></i>
                    </div>
                    <div>
                        <small class="text-muted d-block">خوش آمدید،</small>
                        <h6 class="fw-bold mb-0 text-dark">@(string.IsNullOrEmpty(currentUser.FullName) ? currentUser.Email : currentUser.FullName)</h6>
                    </div>
                </div>
            }

            <!-- متصل به SignalR -->
            <div class="live-status shadow-sm">
                <div>
                    <span class="status-dot me-2"></span>
                    <span id="status-text" class="text-muted">در حال اتصال به سرور...</span>
                </div>
                <div id="driver-count" class="text-primary fs-6">راننده‌های فعال: 0</div>
            </div>

            <!-- 🟩 دکمه‌های اصلی نرم‌افزار 🟩 -->
            <!-- دکمه ورود (فقط وقتی لاگین نیست) -->
            <!-- دکمه ورود (فقط وقتی لاگین نیست) -->
            @if (currentUser == null)
            {
                <a href="/Identity/Account/Login?ReturnUrl=/" class="btn-modern btn-auth-login text-decoration-none">
                    <i class="bi bi-box-arrow-in-right fs-4 me-3"></i>
                    ورود به حساب کاربری
                </a>
            }

            <a href="/Rider/Ride/RequestRide" class="btn-modern btn-rider text-decoration-none">
                <i class="bi bi-person-raised-hand fs-4 me-3"></i>
                درخواست خودرو (مسافر)
            </a>

            <a href="/Driver/Dashboard/Index" class="btn-modern btn-driver text-decoration-none">
                <i class="bi bi-car-front-fill fs-4 me-3"></i>
                ورود به پنل راننده
            </a>

            <!-- پنل ادمین (فقط برای ادمین‌ها) -->
            @if (User.IsInRole(Roles.SuperAdmin) || User.IsInRole(Roles.Admin))
            {
                <a href="/Admin/DriverManagement" class="btn-modern btn-admin text-decoration-none">
                    <i class="bi bi-shield-lock-fill fs-4 me-3"></i>
                    ورود به پنل مدیریت
                </a>
            }

            <!-- دکمه خروج (فقط وقتی لاگین است) -->
            @if (currentUser != null)
            {
                <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post" class="w-100">
                    <button type="submit" class="btn-modern btn-auth-logout w-100">
                        <i class="bi bi-power fs-4 me-3"></i>
                        خروج از حساب
                    </button>
                </form>
            }

            <!-- خط جداکننده -->
            <div class="d-flex align-items-center my-4">
                <hr class="flex-grow-1 text-muted">
                <span class="mx-3 text-muted small">یا</span>
                <hr class="flex-grow-1 text-muted">
            </div>

            <!-- ثبت‌نام راننده جدید -->
            <a href="/Driver/Register/Index" class="btn-modern btn-register text-decoration-none">
                <i class="bi bi-shield-check fs-5 me-2"></i>
                ثبت‌نام به عنوان راننده جدید
            </a>

        </div>
    </div>

</div>

@section Scripts {
    <!-- اسکریپت نقشه که از قبل داشتید -->
    <script src="~/js/map-logic.js"></script>
}